(import (scheme base)
        (scheme process-context)
        (scheme file)
        (scheme write)
        (scheme read)
        (prefix (scheme-reader core) rdr/)
        (paren-repair core)
        (paren-repair token))

(define (%read-tokens port)
  (let ((cell-top (cons '() '())))
    (let loop ((cell cell-top)
               (paren-depth 0))
      (let* ((token (rdr/read-token port))
             (paren-depth-diff
               (cond
                 ((not (rdr/lexical? token)) 0)
                 ((eq? (rdr/lexical-type token) 'OPEN-PAREN) 1)
                 ((eq? (rdr/lexical-type token) 'CLOSE-PAREN) -1)
                 (else 0))))
        (if (eof-object? token)
          (values (cdr cell-top) paren-depth)
          (begin
            (set-cdr! cell (cons token '()))
            (loop (cdr cell)
                  (+ paren-depth paren-depth-diff))))))))

(define (%merge-consecutive-spaces tokens)
  (let loop ((toks tokens)
             (result '()))
    (if (null? toks)
      (reverse result)
      (let ((token (car toks)))
        (if (and (rdr/lexical? token)
                 (eq? (rdr/lexical-type token) 'SPACE))
          (let count-loop ((rest (cdr toks))
                          (n 1))
            (if (and (not (null? rest))
                     (rdr/lexical? (car rest))
                     (eq? (rdr/lexical-type (car rest)) 'SPACE))
              (count-loop (cdr rest) (+ n 1))
              (loop rest (cons (make-multi-space n) result))))
          (loop (cdr toks) (cons token result)))))))

(define (%apply-actions actions)
  (let ((result '()))
    (for-each
      (lambda (action)
        (case (repair-action-type action)
          ((KEEP INSERT)
           (set! result (append result (list (repair-action-value action)))))
          ((DELETE) #f)))
      actions)
    result))

;; トークンを表示用に変換
(define (%token->string token)
  (cond
    ((rdr/lexical? token)
     (case (rdr/lexical-type token)
       ((OPEN-PAREN) "(")
       ((CLOSE-PAREN) ")")
       ((SPACE) (string (rdr/lexical-data token)))
       ((MULTI-SPACE) (rdr/lexical-data token))
       ((NEWLINE) "\n")
       ((STRING) (string-append "\"" (rdr/lexical-data token) "\""))
       ((COMMENT) (string-append ";" (rdr/lexical-data token)))
       ((QUOTE) "'")
       (else (let ((data (rdr/lexical-data token)))
               (cond
                 ((symbol? data) (symbol->string data))
                 ((string? data) data)
                 ((number? data) (rdr/lexical-origin token))
                 ((boolean? data) (if data "#t" "#f"))
                 (else ""))))))
    ((symbol? token) (symbol->string token))
    ((number? token) (number->string token))
    ((boolean? token) (if token "#t" "#f"))
    (else "")))

(define (%tokens->string tokens)
  (apply string-append (map %token->string tokens)))

(define (%repair-paren filename)
  (call-with-input-file
    filename
    (lambda (port)
      (let-values (((raw-tokens depth) (%read-tokens port)))
        (let ((tokens (%merge-consecutive-spaces raw-tokens)))
          (let* ((beam-width 10)
                 (result-state (beam-search tokens beam-width))
               (repaired-tokens (%apply-actions (reverse (state-actions result-state)))))
          (display (%tokens->string repaired-tokens))
          ))))))  ;; let* / let / let-values / lambda / call-with-input-file

(define (%main args)
  (if (null? (cdr args))
    (begin (write "ERROR: usage paren-repair <input-file>.")(newline))
    (%repair-paren (cadr args))))

(%main (command-line))
